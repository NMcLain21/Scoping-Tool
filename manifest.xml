<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xsi:type="TaskPaneApp"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides">

  <!-- ═══ Core identity ═══════════════════════════════════════════ -->
  <Id>7c36b00c-a9ec-4e7f-86eb-bd23e52fe119</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>APi Group</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Scoping Tool" />
  <Description DefaultValue="Apply pre-set colors, fills, and borders to PowerPoint shapes." />

  <!-- ═══ Icons  ═ -->
  <IconUrl DefaultValue="https://nmclain21.github.io/scoping-tool/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://nmclain21.github.io/scoping-tool/icon-80.png" />
  <SupportUrl DefaultValue="https://nmclain21.github.io/scoping-tool/" />

  <!-- ═══ Allowed domains ══════════════════════════════════════════ -->
  <AppDomains>
    <AppDomain>https://nmclain21.github.io</AppDomain>
  </AppDomains>

  <!-- ═══ Host application ═════════════════════════════════════════ -->
  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <!-- ═══ API requirements ═════════════════════════════════════════ -->
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="PresentationAPI" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <!-- ═══ Default task pane source ════════════════════════════════ -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://nmclain21.github.io/scoping-tool/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- ═══ Version overrides — ribbon button + resources ═══════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="ScopingToolGroup">
                <Label resid="Group.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="ScopingToolButton">
                  <Label resid="Button.Label" />
                  <Supertip>
                    <Title resid="Button.Label" />
                    <Description resid="Button.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ScopingToolPane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://nmclain21.github.io/scoping-tool/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://nmclain21.github.io/scoping-tool/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://nmclain21.github.io/scoping-tool/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://nmclain21.github.io/scoping-tool/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Group.Label" DefaultValue="Scoping Tool" />
        <bt:String id="Button.Label" DefaultValue="Scoping Tool" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Button.Tooltip" DefaultValue="Open the Scoping Tool to apply brand colors, fills, and borders to shapes." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
